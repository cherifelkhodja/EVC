---
import BaseLayout from '../layouts/BaseLayout.astro';

const services = [
  {
    icon: 'battery_charging_full',
    title: 'Réparation de batteries haute tension',
    description: 'Votre batterie perd en autonomie ? Nous analysons chaque cellule individuellement et remplaçons uniquement ce qui est défectueux. C\'est plus rapide, moins cher et plus écologique qu\'un remplacement complet.',
    highlights: ["Jusqu'à 80% d'économie", '1 à 5 jours ouvrés', 'Garantie jusqu\'à 2 ans'],
    price: 'À partir de 5 000 € (forfait premium)',
    href: '/batteries',
  },
  {
    icon: 'settings',
    title: 'Réparation de moteurs électriques',
    description: 'Bruit anormal, vibrations, perte de puissance — ce sont souvent les roulements ou des composants internes du moteur. Nous les réparons sans remplacer le moteur entier.',
    highlights: ["Jusqu'à 60% d'économie", 'Small & Large Drive Units', 'Renault Zoe, Tesla, et plus'],
    price: 'À partir de 2 000 € TTC',
    href: '/moteurs',
  },
  {
    icon: 'developer_board',
    title: 'Onduleurs, convertisseurs DC/DC & calculateurs',
    description: 'L\'onduleur, le convertisseur DC/DC et les calculateurs sont le cerveau de votre véhicule. Quand ils tombent en panne, le véhicule peut se retrouver immobilisé. Nous les réparons.',
    highlights: ['Diagnostic avancé', 'Réparation au composant', 'Tarif sur devis'],
    price: 'Sur devis',
    href: '/onduleurs',
  },
];
---

<BaseLayout title="Nos Services | EV Clinic Paris" description="Réparation batteries HV, moteurs électriques, onduleurs et convertisseurs DC/DC. Toutes marques. Devis transparent, garantie incluse.">

  <!-- Hero -->
  <section class="pt-32 pb-16 bg-surface">
    <div class="max-w-7xl mx-auto px-6">
      <span class="inline-block bg-secondary-container text-on-secondary-container px-3 py-1 text-[10px] font-bold tracking-[0.2em] uppercase mb-6">
        Nos services
      </span>
      <h1 class="text-5xl md:text-7xl font-headline font-bold text-on-surface tracking-tighter mb-6">
        Ce que nous faisons
      </h1>
      <p class="text-lg text-on-surface-variant font-light max-w-2xl leading-relaxed">
        Nous réparons les composants les plus coûteux de votre véhicule électrique : batteries, moteurs et électronique de puissance. Toutes marques, particuliers et professionnels.
      </p>
    </div>
  </section>

  <!-- Services -->
  <section class="py-16 bg-surface-container-low">
    <div class="max-w-7xl mx-auto px-6 space-y-px">
      {services.map((service, i) => (
        <a href={service.href} class="block bg-surface-container-lowest p-12 hover:bg-surface-bright transition-colors group">
          <div class="grid grid-cols-1 md:grid-cols-12 gap-8 items-start">
            <div class="md:col-span-1">
              <span class="text-4xl font-headline font-bold text-outline-variant/30">0{i + 1}</span>
            </div>
            <div class="md:col-span-6">
              <div class="mb-4 text-primary">
                <span class="material-symbols-outlined text-3xl" style="font-variation-settings: 'FILL' 1;">{service.icon}</span>
              </div>
              <h2 class="text-2xl font-headline font-bold text-on-surface mb-4">{service.title}</h2>
              <p class="text-on-surface-variant font-light leading-relaxed mb-4">{service.description}</p>
              <p class="text-sm font-medium text-primary mb-6">{service.price}</p>
              <span class="inline-flex items-center gap-2 bg-gradient-to-r from-primary to-primary-container text-on-primary px-6 py-3 rounded-md font-headline font-bold text-sm tracking-tight group-hover:opacity-90 transition-opacity">
                En savoir plus
                <span class="material-symbols-outlined text-sm">arrow_forward</span>
              </span>
            </div>
            <div class="md:col-span-4 md:col-start-9">
              <ul class="space-y-3">
                {service.highlights.map((h) => (
                  <li class="flex items-center gap-3">
                    <span class="material-symbols-outlined text-primary text-sm">check_circle</span>
                    <span class="text-on-surface-variant">{h}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- Vehicle-Specific -->
  <section class="py-16 bg-surface">
    <div class="max-w-7xl mx-auto px-6">
      <h2 class="text-3xl font-headline font-bold text-on-surface mb-4 tracking-tight">Problèmes fréquents par marque</h2>
      <p class="text-on-surface-variant font-light mb-12 max-w-2xl">Certaines pannes reviennent souvent selon les modèles. Nous les connaissons et savons les traiter efficacement.</p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-px bg-outline-variant/15">
        <div class="bg-surface-container-lowest p-10">
          <h3 class="font-headline font-bold text-on-surface mb-3 text-lg">Renault Zoe</h3>
          <p class="text-on-surface-variant font-light text-sm leading-relaxed mb-3">
            Le roulement moteur est un point faible connu de la Zoe. Symptômes : bruit de roulement, bourdonnement à vitesse constante, vibrations.
          </p>
          <p class="text-sm text-primary font-medium">Réparation roulement ou moteur échange standard</p>
        </div>
        <div class="bg-surface-container-lowest p-10">
          <h3 class="font-headline font-bold text-on-surface mb-3 text-lg">Tesla Model S/X/3/Y</h3>
          <p class="text-on-surface-variant font-light text-sm leading-relaxed mb-3">
            Les Large Drive Units (LDU) peuvent développer des bruits ou des pertes de performance avec le temps et les kilomètres.
          </p>
          <p class="text-sm text-primary font-medium">Réparation LDU spécialisée</p>
        </div>
        <div class="bg-surface-container-lowest p-10">
          <h3 class="font-headline font-bold text-on-surface mb-3 text-lg">BMW i3 / Hyundai Ioniq 5</h3>
          <p class="text-on-surface-variant font-light text-sm leading-relaxed mb-3">
            Dégradation de cellules batterie, erreurs BMS, problèmes de convertisseur DC/DC — des pannes que nous traitons régulièrement.
          </p>
          <p class="text-sm text-primary font-medium">Diagnostic et réparation ciblée</p>
        </div>
      </div>
    </div>
  </section>

  <!-- All Brands -->
  <section class="py-16 bg-surface-container-low">
    <div class="max-w-7xl mx-auto px-6 text-center">
      <p class="text-xs font-bold tracking-[0.2em] uppercase text-on-surface-variant mb-10">Toutes marques prises en charge</p>
      <div class="flex flex-wrap justify-center gap-x-10 gap-y-4 text-lg font-headline font-bold text-on-surface-variant/60">
        <span class="hover:text-on-surface transition-colors cursor-default">Tesla</span>
        <span class="hover:text-on-surface transition-colors cursor-default">BMW</span>
        <span class="hover:text-on-surface transition-colors cursor-default">Renault</span>
        <span class="hover:text-on-surface transition-colors cursor-default">Volkswagen</span>
        <span class="hover:text-on-surface transition-colors cursor-default">Audi</span>
        <span class="hover:text-on-surface transition-colors cursor-default">Hyundai</span>
        <span class="hover:text-on-surface transition-colors cursor-default">Mercedes</span>
        <span class="hover:text-on-surface transition-colors cursor-default">Peugeot</span>
        <span class="hover:text-on-surface transition-colors cursor-default">Kia</span>
        <span class="hover:text-on-surface transition-colors cursor-default">Porsche</span>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 bg-surface">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <h2 class="text-3xl font-headline font-bold text-on-surface mb-6 tracking-tight">Vous avez un problème avec votre véhicule ?</h2>
      <p class="text-on-surface-variant font-light mb-8">Décrivez-nous votre situation. Nous vous répondrons rapidement avec un premier avis et une estimation.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/reservation" class="inline-block bg-gradient-to-r from-primary to-primary-container text-on-primary px-12 py-5 rounded-md font-headline font-bold tracking-tight hover:opacity-90 transition-all">
          Prendre rendez-vous
        </a>
        <a href="mailto:contact@evclinic.fr" class="inline-block bg-surface-container-highest text-on-secondary-container px-12 py-5 rounded-md font-headline font-bold tracking-tight hover:bg-surface-container-high transition-all">
          Envoyer un email
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
