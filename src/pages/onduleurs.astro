---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Onduleurs & Convertisseurs DC/DC | EV Clinic Paris" description="Réparation d'onduleurs, convertisseurs DC/DC et calculateurs (ECU) pour véhicules électriques. Diagnostic précis, réparation au composant.">

  <!-- Hero -->
  <section class="pt-32 pb-16 bg-surface">
    <div class="max-w-7xl mx-auto px-6">
      <a href="/services" class="inline-flex items-center gap-2 text-sm text-on-surface-variant hover:text-primary transition-colors mb-8">
        <span class="material-symbols-outlined text-sm">arrow_back</span>
        Retour aux services
      </a>
      <span class="inline-block bg-secondary-container text-on-secondary-container px-3 py-1 text-[10px] font-bold tracking-[0.2em] uppercase mb-6">
        Électronique de puissance
      </span>
      <h1 class="text-5xl md:text-6xl font-headline font-bold text-on-surface tracking-tighter mb-6">
        Panne électronique ? On s'en occupe.
      </h1>
      <p class="text-lg text-on-surface-variant font-light max-w-2xl leading-relaxed">
        L'onduleur, le convertisseur DC/DC et les calculateurs sont les composants électroniques vitaux de votre véhicule. Quand l'un d'eux tombe en panne, le véhicule peut se retrouver immobilisé. Nous les diagnostiquons et les réparons.
      </p>
    </div>
  </section>

  <!-- What are these components -->
  <section class="py-16 bg-surface-container-low">
    <div class="max-w-7xl mx-auto px-6">
      <h2 class="text-3xl font-headline font-bold text-on-surface mb-4 tracking-tight">C'est quoi exactement ?</h2>
      <p class="text-on-surface-variant font-light mb-12 max-w-2xl">Voici les 3 composants électroniques clés de votre véhicule, expliqués simplement :</p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-px bg-outline-variant/15">

        <div class="bg-surface-container-lowest p-12">
          <div class="mb-6 text-primary">
            <span class="material-symbols-outlined text-3xl" style="font-variation-settings: 'FILL' 1;">electric_bolt</span>
          </div>
          <h3 class="text-xl font-headline font-bold text-on-surface mb-3">L'onduleur</h3>
          <p class="text-on-surface-variant font-light leading-relaxed mb-6">
            Il transforme le courant de la batterie (continu) en courant pour le moteur (alternatif). Sans lui, le moteur ne tourne pas.
          </p>
          <h4 class="font-bold text-on-surface text-sm mb-3">Symptômes de panne :</h4>
          <ul class="space-y-2 text-sm text-on-surface-variant">
            <li class="flex items-start gap-2">
              <span class="material-symbols-outlined text-error text-sm shrink-0 mt-0.5">warning</span>
              Perte de puissance soudaine
            </li>
            <li class="flex items-start gap-2">
              <span class="material-symbols-outlined text-error text-sm shrink-0 mt-0.5">warning</span>
              Véhicule en mode dégradé
            </li>
            <li class="flex items-start gap-2">
              <span class="material-symbols-outlined text-error text-sm shrink-0 mt-0.5">warning</span>
              Erreur système de traction
            </li>
          </ul>
        </div>

        <div class="bg-surface-container-lowest p-12">
          <div class="mb-6 text-primary">
            <span class="material-symbols-outlined text-3xl" style="font-variation-settings: 'FILL' 1;">transform</span>
          </div>
          <h3 class="text-xl font-headline font-bold text-on-surface mb-3">Le convertisseur DC/DC</h3>
          <p class="text-on-surface-variant font-light leading-relaxed mb-6">
            Il convertit la haute tension de la batterie principale en 12V pour alimenter les phares, la radio, le GPS et toute l'électronique de bord.
          </p>
          <h4 class="font-bold text-on-surface text-sm mb-3">Symptômes de panne :</h4>
          <ul class="space-y-2 text-sm text-on-surface-variant">
            <li class="flex items-start gap-2">
              <span class="material-symbols-outlined text-error text-sm shrink-0 mt-0.5">warning</span>
              Batterie 12V qui se décharge sans raison
            </li>
            <li class="flex items-start gap-2">
              <span class="material-symbols-outlined text-error text-sm shrink-0 mt-0.5">warning</span>
              Électronique de bord défaillante
            </li>
            <li class="flex items-start gap-2">
              <span class="material-symbols-outlined text-error text-sm shrink-0 mt-0.5">warning</span>
              Véhicule qui ne démarre plus
            </li>
          </ul>
        </div>

        <div class="bg-surface-container-lowest p-12">
          <div class="mb-6 text-primary">
            <span class="material-symbols-outlined text-3xl" style="font-variation-settings: 'FILL' 1;">developer_board</span>
          </div>
          <h3 class="text-xl font-headline font-bold text-on-surface mb-3">Les calculateurs (ECU)</h3>
          <p class="text-on-surface-variant font-light leading-relaxed mb-6">
            Ce sont les « cerveaux » du véhicule : gestion de la batterie (BMS), contrôle du moteur, gestion thermique. Ils coordonnent tout.
          </p>
          <h4 class="font-bold text-on-surface text-sm mb-3">Symptômes de panne :</h4>
          <ul class="space-y-2 text-sm text-on-surface-variant">
            <li class="flex items-start gap-2">
              <span class="material-symbols-outlined text-error text-sm shrink-0 mt-0.5">warning</span>
              Codes défauts multiples
            </li>
            <li class="flex items-start gap-2">
              <span class="material-symbols-outlined text-error text-sm shrink-0 mt-0.5">warning</span>
              Comportement erratique
            </li>
            <li class="flex items-start gap-2">
              <span class="material-symbols-outlined text-error text-sm shrink-0 mt-0.5">warning</span>
              Limitation de charge inexpliquée
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Our approach -->
  <section class="py-16 bg-surface">
    <div class="max-w-7xl mx-auto px-6 grid grid-cols-1 md:grid-cols-2 gap-16 items-center">
      <div>
        <h2 class="text-3xl font-headline font-bold text-on-surface mb-6 tracking-tight">Comment on procède</h2>
        <p class="text-on-surface-variant font-light leading-relaxed mb-8">
          Contrairement à un garage classique qui remplace le module complet (souvent plusieurs milliers d'euros), nous diagnostiquons au niveau du composant électronique et réparons uniquement ce qui est en panne.
        </p>
        <div class="space-y-6">
          {[
            { step: '1', title: 'Diagnostic électronique', desc: 'Lecture des codes défauts, analyse des signaux, mesures de tension et courant sur chaque module.' },
            { step: '2', title: 'Réparation ciblée', desc: 'Remplacement des composants défaillants : IGBT, MOSFETs, condensateurs, circuits de commande.' },
            { step: '3', title: 'Validation complète', desc: 'Tests fonctionnels, vérification des protocoles de communication CAN bus, essai sur véhicule.' },
          ].map((item) => (
            <div class="flex items-start gap-4">
              <div class="w-8 h-8 flex items-center justify-center bg-secondary-container text-on-secondary-container font-headline font-bold text-xs shrink-0">{item.step}</div>
              <div>
                <h4 class="font-bold text-on-surface">{item.title}</h4>
                <p class="text-sm text-on-surface-variant">{item.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
      <div class="bg-surface-container-low p-12">
        <h3 class="font-headline font-bold text-on-surface mb-8">En chiffres</h3>
        <div class="space-y-8">
          <div>
            <div class="text-[10px] text-zinc-500 uppercase tracking-widest mb-2">Temps de diagnostic</div>
            <div class="text-4xl font-headline font-bold text-on-surface">2-4h</div>
          </div>
          <div>
            <div class="text-[10px] text-zinc-500 uppercase tracking-widest mb-2">Délai de réparation</div>
            <div class="text-4xl font-headline font-bold text-primary">3-5 jours</div>
          </div>
          <div>
            <div class="text-[10px] text-zinc-500 uppercase tracking-widest mb-2">Tarif</div>
            <div class="text-4xl font-headline font-bold text-on-surface">Sur devis</div>
            <p class="text-xs text-on-surface-variant mt-1">Gratuit et sans engagement</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 bg-surface-container-low">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <h2 class="text-3xl font-headline font-bold text-on-surface mb-6 tracking-tight">Un problème électronique sur votre véhicule ?</h2>
      <p class="text-on-surface-variant font-light mb-8">Codes défauts, véhicule immobilisé, comportement anormal — décrivez-nous la situation.</p>
      <a href="/reservation" class="inline-block bg-gradient-to-r from-primary to-primary-container text-on-primary px-12 py-5 rounded-md font-headline font-bold tracking-tight hover:opacity-90 transition-all">
        Demander un diagnostic
      </a>
    </div>
  </section>

</BaseLayout>
