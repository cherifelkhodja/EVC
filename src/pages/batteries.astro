---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Réparation Batteries Haute Tension | EV Clinic Paris" description="Réparation et reconditionnement de batteries haute tension pour véhicules électriques. Diagnostic cellulaire, remplacement ciblé. Jusqu'à 70% d'économie. Garantie jusqu'à 2 ans.">

  <!-- Hero -->
  <section class="pt-32 pb-16 bg-surface">
    <div class="max-w-7xl mx-auto px-6">
      <a href="/services" class="inline-flex items-center gap-2 text-sm text-on-surface-variant hover:text-primary transition-colors mb-8">
        <span class="material-symbols-outlined text-sm">arrow_back</span>
        Retour aux services
      </a>
      <div class="grid grid-cols-1 md:grid-cols-12 gap-12">
        <div class="md:col-span-7">
          <span class="inline-block bg-secondary-container text-on-secondary-container px-3 py-1 text-[10px] font-bold tracking-[0.2em] uppercase mb-6">
            Batterie haute tension
          </span>
          <h1 class="text-5xl md:text-6xl font-headline font-bold text-on-surface tracking-tighter mb-6">
            Votre batterie perd en autonomie ?
          </h1>
          <p class="text-lg text-on-surface-variant font-light max-w-xl leading-relaxed">
            Pas besoin de remplacer toute la batterie. Nous identifions les cellules défectueuses et ne remplaçons que ce qui est nécessaire. C'est plus rapide, moins cher, et plus écologique.
          </p>
        </div>
        <div class="md:col-span-5 flex items-center">
          <div class="bg-surface-container-low p-10 w-full">
            <div class="grid grid-cols-2 gap-6">
              <div>
                <div class="text-[10px] text-zinc-500 uppercase tracking-widest mb-2">Économie</div>
                <div class="text-5xl font-headline font-bold text-primary">70%</div>
                <p class="text-xs text-on-surface-variant mt-1">vs remplacement complet</p>
              </div>
              <div>
                <div class="text-[10px] text-zinc-500 uppercase tracking-widest mb-2">Délai</div>
                <div class="text-5xl font-headline font-bold text-on-surface">1-3</div>
                <p class="text-xs text-on-surface-variant mt-1">jours ouvrés</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Symptoms -->
  <section class="py-16 bg-surface-container-low">
    <div class="max-w-7xl mx-auto px-6">
      <h2 class="text-3xl font-headline font-bold text-on-surface mb-4 tracking-tight">Quand faut-il nous consulter ?</h2>
      <p class="text-on-surface-variant font-light mb-12 max-w-2xl">Voici les signes qui indiquent que votre batterie a besoin d'attention :</p>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-px bg-outline-variant/15">
        {[
          { icon: 'battery_alert', title: 'Perte d\'autonomie', desc: 'Votre véhicule parcourt moins de kilomètres qu\'avant avec une charge complète.' },
          { icon: 'error', title: 'Message d\'erreur', desc: 'Le tableau de bord affiche une alerte liée à la batterie ou au système haute tension.' },
          { icon: 'speed', title: 'Charge lente', desc: 'La batterie met plus de temps à charger ou ne se charge plus complètement.' },
          { icon: 'thermostat', title: 'Surchauffe', desc: 'La batterie chauffe anormalement pendant la charge ou la conduite.' },
        ].map((item) => (
          <div class="bg-surface-container-lowest p-8">
            <span class="material-symbols-outlined text-primary text-2xl mb-4 block" style="font-variation-settings: 'FILL' 1;">{item.icon}</span>
            <h3 class="font-bold text-on-surface mb-2">{item.title}</h3>
            <p class="text-sm text-on-surface-variant font-light leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Process -->
  <section class="py-16 bg-surface">
    <div class="max-w-7xl mx-auto px-6">
      <h2 class="text-3xl font-headline font-bold text-on-surface mb-12 tracking-tight">Notre processus, étape par étape</h2>
      <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
        {[
          { step: '1', title: 'Diagnostic cellulaire', desc: 'Nous mesurons la tension, la résistance et la capacité de chaque cellule individuellement. On identifie exactement ce qui ne fonctionne pas.' },
          { step: '2', title: 'Rapport et devis', desc: 'Vous recevez un rapport clair : quelles cellules sont défectueuses, quel est le coût et le délai. Vous décidez.' },
          { step: '3', title: 'Réparation ciblée', desc: 'Remplacement des cellules défectueuses, équilibrage du pack batterie, recalibration du système de gestion (BMS).' },
          { step: '4', title: 'Tests et garantie', desc: 'Tests complets de charge et décharge. Vérification thermique. Vous repartez avec une garantie écrite.' },
        ].map((item) => (
          <div>
            <div class="text-5xl font-headline font-bold text-outline-variant/20 mb-4">{item.step}</div>
            <h3 class="font-headline font-bold text-on-surface mb-2">{item.title}</h3>
            <p class="text-sm text-on-surface-variant font-light leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Pricing -->
  <section class="py-16 bg-surface-container-low">
    <div class="max-w-7xl mx-auto px-6">
      <h2 class="text-3xl font-headline font-bold text-on-surface mb-12 tracking-tight">Tarifs</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-px bg-outline-variant/15">
        <div class="bg-surface-container-lowest p-12">
          <h3 class="text-xl font-headline font-bold text-on-surface mb-2">Réparation standard</h3>
          <p class="text-sm text-on-surface-variant mb-6">Remplacement de cellules défectueuses (jusqu'à 6 cellules), équilibrage et recalibration BMS.</p>
          <div class="text-4xl font-headline font-bold text-primary mb-6">Sur devis</div>
          <div class="space-y-3 text-sm">
            <div class="flex items-center gap-3">
              <span class="material-symbols-outlined text-primary text-sm">schedule</span>
              <span class="text-on-surface-variant">1 à 3 jours ouvrés</span>
            </div>
            <div class="flex items-center gap-3">
              <span class="material-symbols-outlined text-primary text-sm">verified</span>
              <span class="text-on-surface-variant">Garantie 1 an</span>
            </div>
          </div>
        </div>
        <div class="bg-surface-container-lowest p-12 relative overflow-hidden">
          <span class="absolute top-4 right-4 bg-primary text-on-primary px-3 py-1 text-[10px] font-bold tracking-wider uppercase">Recommandé</span>
          <h3 class="text-xl font-headline font-bold text-on-surface mb-2">Réparation premium</h3>
          <p class="text-sm text-on-surface-variant mb-6">Reconditionnement complet avec diagnostic approfondi et remplacement étendu.</p>
          <div class="text-4xl font-headline font-bold text-primary mb-6">5 000 €</div>
          <div class="space-y-3 text-sm">
            <div class="flex items-center gap-3">
              <span class="material-symbols-outlined text-primary text-sm">schedule</span>
              <span class="text-on-surface-variant">Environ 10 jours ouvrés</span>
            </div>
            <div class="flex items-center gap-3">
              <span class="material-symbols-outlined text-primary text-sm">verified</span>
              <span class="text-on-surface-variant font-medium text-on-surface">Garantie 2 ans, sans limite de kilométrage</span>
            </div>
          </div>
        </div>
      </div>
      <p class="text-sm text-on-surface-variant mt-6 font-light">Tous les tarifs sont TTC. Le devis est gratuit et sans engagement.</p>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 bg-surface">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <h2 class="text-3xl font-headline font-bold text-on-surface mb-6 tracking-tight">Problème de batterie ?</h2>
      <p class="text-on-surface-variant font-light mb-8">Décrivez-nous les symptômes. Nous vous dirons rapidement si une réparation est possible et à quel coût.</p>
      <a href="/reservation" class="inline-block bg-gradient-to-r from-primary to-primary-container text-on-primary px-12 py-5 rounded-md font-headline font-bold tracking-tight hover:opacity-90 transition-all">
        Demander un diagnostic batterie
      </a>
    </div>
  </section>

</BaseLayout>
