---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="EV Clinic Paris | Réparation Véhicules Électriques à Antony" description="Atelier spécialisé dans la réparation de véhicules électriques en Île-de-France. Batteries, moteurs, onduleurs. Jusqu'à 70% moins cher qu'un remplacement. Sur rendez-vous.">

  <!-- Hero Section -->
  <section class="relative min-h-screen flex items-center overflow-hidden bg-surface">
    <div class="absolute inset-0 z-0">
      <div class="absolute inset-0 bg-gradient-to-r from-surface via-surface/60 to-transparent z-10"></div>
      <img
        alt="Atelier de réparation véhicules électriques EV Clinic Paris"
        class="w-full h-full object-cover"
        src="https://lh3.googleusercontent.com/aida-public/AB6AXuCnQ22ms4JuSi-Rek0-9RTWKfJS0qDq4aVHXerJDt-A0AoOhGwrweD74JX6R3CrwNUqPHCg0PVWF6YZMZztf8YIlhZdyR2SPU0BGfyWZkli98EZJkAtAyT4BV1PBaQHKrD9eSUurjgtv1O46MmxACettnudbb5tMwUTwyoWO6LsYwHhwSKLXz4wgRrUL_a6wbeTYyDijmFSn2kfhpwCzytfQQ5S7mkAkJKugb3AnId3Q8aSUpigrbNJl_3pIw1lIqtPN_LkyqYR9KrH"
      />
    </div>

    <div class="relative z-20 max-w-7xl mx-auto px-6 w-full pt-20">
      <div class="max-w-2xl">
        <span class="inline-block bg-secondary-container text-on-secondary-container px-3 py-1 text-[10px] font-bold tracking-[0.2em] uppercase mb-6 rounded-none">
          Spécialiste véhicules électriques
        </span>
        <h1 class="text-5xl md:text-7xl font-headline font-bold leading-[0.9] text-on-surface mb-8 tracking-tighter">
          Votre véhicule électrique entre de bonnes mains
        </h1>
        <p class="text-lg text-on-surface-variant max-w-lg mb-10 leading-relaxed font-light">
          Batterie fatiguée, moteur bruyant, perte de puissance ? Nous diagnostiquons et réparons les composants critiques de votre véhicule électrique — sans le remplacer entièrement.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a
            href="/reservation"
            class="bg-gradient-to-r from-primary to-primary-container text-on-primary px-10 py-5 rounded-md font-headline font-bold tracking-tight hover:opacity-90 transition-all text-center"
          >
            Prendre rendez-vous
          </a>
          <a
            href="/services"
            class="bg-surface-container-highest text-on-secondary-container px-10 py-5 rounded-md font-headline font-bold tracking-tight hover:bg-surface-container-high transition-all text-center"
          >
            Voir nos services
          </a>
        </div>
      </div>
    </div>

    <!-- Stats Card -->
    <div class="absolute bottom-12 right-12 hidden lg:block z-20">
      <div class="bg-white/60 backdrop-blur-xl p-8 rounded-xl border border-white/20 shadow-2xl">
        <div class="flex items-center gap-4 mb-4">
          <div class="h-2 w-12 bg-primary rounded-full"></div>
          <span class="font-headline text-xs font-bold tracking-widest uppercase">Pourquoi nous choisir</span>
        </div>
        <div class="grid grid-cols-2 gap-8">
          <div>
            <div class="text-[10px] text-zinc-500 uppercase tracking-widest mb-1">Économie</div>
            <div class="text-3xl font-headline font-bold text-on-surface">-70%</div>
          </div>
          <div>
            <div class="text-[10px] text-zinc-500 uppercase tracking-widest mb-1">Garantie</div>
            <div class="text-3xl font-headline font-bold text-primary">2 ans</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Trust Signals -->
  <section class="py-16 bg-surface-container-low border-b border-outline-variant/15">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
        <div>
          <div class="text-3xl font-headline font-bold text-primary mb-1">70%</div>
          <p class="text-sm text-on-surface-variant">d'économie vs remplacement</p>
        </div>
        <div>
          <div class="text-3xl font-headline font-bold text-primary mb-1">1-3 j</div>
          <p class="text-sm text-on-surface-variant">délai moyen d'intervention</p>
        </div>
        <div>
          <div class="text-3xl font-headline font-bold text-primary mb-1">2 ans</div>
          <p class="text-sm text-on-surface-variant">de garantie (offre premium)</p>
        </div>
        <div>
          <div class="text-3xl font-headline font-bold text-primary mb-1">15+</div>
          <p class="text-sm text-on-surface-variant">années d'expertise EV</p>
        </div>
      </div>
    </div>
  </section>

  <!-- What We Do (simple, clear) -->
  <section class="py-24 bg-surface">
    <div class="max-w-7xl mx-auto px-6">
      <div class="max-w-xl mb-16">
        <h2 class="text-4xl md:text-5xl font-headline font-bold text-on-surface mb-6 tracking-tight">Ce que nous réparons</h2>
        <p class="text-on-surface-variant font-light leading-relaxed">Nous intervenons sur les composants les plus coûteux de votre véhicule électrique. Réparer au lieu de remplacer, c'est économique et écologique.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-px bg-outline-variant/15">
        <a href="/batteries" class="bg-surface-container-lowest p-12 hover:bg-surface-bright transition-colors group block">
          <div class="mb-6 text-primary">
            <span class="material-symbols-outlined text-4xl" style="font-variation-settings: 'FILL' 1;">battery_charging_full</span>
          </div>
          <h3 class="text-2xl font-headline font-bold text-on-surface mb-3">Batteries haute tension</h3>
          <p class="text-on-surface-variant font-light leading-relaxed mb-2">
            Votre batterie perd en autonomie ou affiche une erreur ? Nous diagnostiquons chaque cellule et remplaçons uniquement ce qui est défectueux.
          </p>
          <p class="text-sm text-primary font-medium mb-6">Jusqu'à 70% moins cher qu'un remplacement complet</p>
          <div class="h-1 w-0 group-hover:w-full bg-primary transition-all duration-300"></div>
        </a>

        <a href="/moteurs" class="bg-surface-container-lowest p-12 hover:bg-surface-bright transition-colors group block">
          <div class="mb-6 text-primary">
            <span class="material-symbols-outlined text-4xl" style="font-variation-settings: 'FILL' 1;">settings</span>
          </div>
          <h3 class="text-2xl font-headline font-bold text-on-surface mb-3">Moteurs électriques</h3>
          <p class="text-on-surface-variant font-light leading-relaxed mb-2">
            Bruit anormal, vibrations, perte de puissance ? Nous réparons les roulements, le stator et le rotor pour restaurer les performances d'origine.
          </p>
          <p class="text-sm text-primary font-medium mb-6">À partir de 2 000 €, en 4-5 jours</p>
          <div class="h-1 w-0 group-hover:w-full bg-primary transition-all duration-300"></div>
        </a>

        <a href="/onduleurs" class="bg-surface-container-lowest p-12 hover:bg-surface-bright transition-colors group block">
          <div class="mb-6 text-primary">
            <span class="material-symbols-outlined text-4xl" style="font-variation-settings: 'FILL' 1;">developer_board</span>
          </div>
          <h3 class="text-2xl font-headline font-bold text-on-surface mb-3">Électronique de puissance</h3>
          <p class="text-on-surface-variant font-light leading-relaxed mb-2">
            Onduleurs, convertisseurs DC/DC, unités de contrôle — nous réparons l'électronique qui fait fonctionner votre véhicule.
          </p>
          <p class="text-sm text-primary font-medium mb-6">Diagnostic précis, réparation ciblée</p>
          <div class="h-1 w-0 group-hover:w-full bg-primary transition-all duration-300"></div>
        </a>
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="py-24 bg-surface-container-low">
    <div class="max-w-7xl mx-auto px-6">
      <h2 class="text-4xl font-headline font-bold text-on-surface mb-16 tracking-tight">Comment ça marche</h2>
      <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
        {[
          { step: '1', title: 'Vous nous contactez', desc: 'Décrivez votre problème par email ou via notre formulaire. Nous vous proposons un créneau rapidement.' },
          { step: '2', title: 'Diagnostic complet', desc: 'Nous analysons votre véhicule en profondeur : batterie, moteur, électronique. Vous recevez un rapport clair.' },
          { step: '3', title: 'Devis transparent', desc: 'Avant toute intervention, vous connaissez le coût exact et le délai. Pas de surprise.' },
          { step: '4', title: 'Réparation & garantie', desc: 'Nous réparons votre véhicule et le testons. Vous repartez avec une garantie écrite.' },
        ].map((item) => (
          <div class="relative">
            <div class="text-6xl font-headline font-bold text-outline-variant/20 mb-4">{item.step}</div>
            <h3 class="text-lg font-headline font-bold text-on-surface mb-2">{item.title}</h3>
            <p class="text-sm text-on-surface-variant font-light leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Why Us -->
  <section class="py-24 bg-surface">
    <div class="max-w-7xl mx-auto px-6 grid grid-cols-1 md:grid-cols-12 gap-12 items-center">
      <div class="md:col-span-7">
        <div class="relative">
          <img
            alt="Diagnostic véhicule électrique"
            class="w-full aspect-video object-cover grayscale hover:grayscale-0 transition-all duration-700"
            src="https://lh3.googleusercontent.com/aida-public/AB6AXuD-chONyrXBOV2apsgmuOvyKLSx_4KVDfti_RL9T3TZv2QazEVWBggZuUiVcsTjXpDGc0nx1pBhAKKwYTaNRheD7U1LtjvflGWylke-bjiiKV4OLupAX__4jPG2NPpapLDnXj5-GSBR33ypHwssnZCERJlAO-7FAt5uULX0ylYdgXx0g1-iCsrUxJUajEQUDv7Aof_EfrYOJd8M9QO-eGvnHCsvaI3nQWBdlxQGqJNzJKLCTf_GibroPJN_q5fNQ00R8uIoeGqbhYvK"
          />
          <div class="absolute -bottom-8 -right-8 bg-primary p-12 hidden lg:block">
            <span class="material-symbols-outlined text-white text-5xl">verified</span>
          </div>
        </div>
      </div>
      <div class="md:col-span-5 md:pl-12">
        <h2 class="text-4xl font-headline font-bold text-on-surface mb-6 leading-tight">Pourquoi choisir EV Clinic ?</h2>
        <p class="text-on-surface-variant font-light mb-8 leading-relaxed">
          Nous ne sommes pas un garage généraliste. Nous sommes des spécialistes du véhicule électrique, formés aux technologies haute tension et à l'électronique de puissance.
        </p>
        <div class="space-y-6">
          <div class="flex items-start gap-4">
            <div class="w-8 h-8 flex items-center justify-center bg-secondary-container text-on-secondary-container font-headline font-bold text-xs shrink-0">
              <span class="material-symbols-outlined text-primary text-base">savings</span>
            </div>
            <div>
              <h4 class="font-bold text-on-surface">Économique</h4>
              <p class="text-sm text-on-surface-variant">Réparer coûte 60 à 70% moins cher que remplacer un composant neuf.</p>
            </div>
          </div>
          <div class="flex items-start gap-4">
            <div class="w-8 h-8 flex items-center justify-center bg-secondary-container text-on-secondary-container font-headline font-bold text-xs shrink-0">
              <span class="material-symbols-outlined text-primary text-base">speed</span>
            </div>
            <div>
              <h4 class="font-bold text-on-surface">Rapide</h4>
              <p class="text-sm text-on-surface-variant">La plupart des réparations sont terminées en 1 à 5 jours ouvrés.</p>
            </div>
          </div>
          <div class="flex items-start gap-4">
            <div class="w-8 h-8 flex items-center justify-center bg-secondary-container text-on-secondary-container font-headline font-bold text-xs shrink-0">
              <span class="material-symbols-outlined text-primary text-base">eco</span>
            </div>
            <div>
              <h4 class="font-bold text-on-surface">Durable</h4>
              <p class="text-sm text-on-surface-variant">Réparer plutôt que jeter : moins de déchets, moins de ressources consommées.</p>
            </div>
          </div>
          <div class="flex items-start gap-4">
            <div class="w-8 h-8 flex items-center justify-center bg-secondary-container text-on-secondary-container font-headline font-bold text-xs shrink-0">
              <span class="material-symbols-outlined text-primary text-base">public</span>
            </div>
            <div>
              <h4 class="font-bold text-on-surface">Réseau international</h4>
              <p class="text-sm text-on-surface-variant">EV Clinic est présent à Zagreb, Berlin et Paris. Un savoir-faire partagé entre experts européens.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Brands -->
  <section class="py-16 bg-surface-container-low">
    <div class="max-w-7xl mx-auto px-6 text-center">
      <p class="text-xs font-bold tracking-[0.2em] uppercase text-on-surface-variant mb-10">Nous intervenons sur toutes les marques</p>
      <div class="flex flex-wrap justify-center gap-x-12 gap-y-4 text-xl font-headline font-bold text-outline-variant/40">
        <span>Tesla</span>
        <span>BMW</span>
        <span>Renault</span>
        <span>Volkswagen</span>
        <span>Audi</span>
        <span>Hyundai</span>
        <span>Mercedes</span>
        <span>Peugeot</span>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-24 bg-surface">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <h2 class="text-4xl md:text-5xl font-headline font-bold text-on-surface mb-6 tracking-tight">
        Un doute sur l'état de votre véhicule ?
      </h2>
      <p class="text-on-surface-variant font-light mb-10 leading-relaxed text-lg">
        Contactez-nous pour un diagnostic. Nous vous expliquerons clairement ce qui ne va pas, combien ça coûte et combien de temps ça prend.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/reservation"
          class="inline-block bg-gradient-to-r from-primary to-primary-container text-on-primary px-12 py-5 rounded-md font-headline font-bold tracking-tight hover:opacity-90 transition-all"
        >
          Prendre rendez-vous
        </a>
        <a
          href="mailto:contact@evclinic.fr"
          class="inline-block bg-surface-container-highest text-on-secondary-container px-12 py-5 rounded-md font-headline font-bold tracking-tight hover:bg-surface-container-high transition-all"
        >
          contact@evclinic.fr
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
