---
import BaseLayout from '../layouts/BaseLayout.astro';

const pricing = [
  {
    name: 'Small Drive Unit',
    description: 'Réparation moteur électrique — petite unité de traction',
    price: '2 000 €',
    turnaround: '4-5 jours ouvrés',
  },
  {
    name: 'Large Drive Unit (sans stator)',
    description: 'Réparation moteur électrique — grande unité de traction',
    price: '4 200 €',
    turnaround: '5-8 jours ouvrés',
  },
];
---

<BaseLayout title="Réparation Moteurs Électriques | EV Clinic Paris" description="Réparation et reconditionnement de moteurs électriques pour véhicules électriques. Jusqu'à 60% moins cher qu'un remplacement. Small et Large Drive Units.">

  <!-- Hero -->
  <section class="pt-32 pb-20 bg-surface">
    <div class="max-w-7xl mx-auto px-6">
      <a href="/services" class="inline-flex items-center gap-2 text-sm text-on-surface-variant hover:text-primary transition-colors mb-8">
        <span class="material-symbols-outlined text-sm">arrow_back</span>
        Retour aux services
      </a>
      <div class="grid grid-cols-1 md:grid-cols-12 gap-12">
        <div class="md:col-span-7">
          <span class="inline-block bg-secondary-container text-on-secondary-container px-3 py-1 text-[10px] font-bold tracking-[0.2em] uppercase mb-6">
            Moteur électrique
          </span>
          <h1 class="text-5xl md:text-7xl font-headline font-bold text-on-surface tracking-tighter mb-6">
            Réparation & Reconditionnement Moteurs
          </h1>
          <p class="text-lg text-on-surface-variant font-light max-w-xl leading-relaxed">
            Réparation professionnelle, durable et économique de moteurs électriques. Roulements, stator, rotor — nous restaurons les performances d'origine.
          </p>
        </div>
        <div class="md:col-span-5 flex items-center">
          <div class="bg-surface-container-low p-10 w-full">
            <div class="text-[10px] text-zinc-500 uppercase tracking-widest mb-2">Économie moyenne</div>
            <div class="text-6xl font-headline font-bold text-primary mb-4">60%</div>
            <p class="text-sm text-on-surface-variant">moins cher qu'un remplacement de moteur complet</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Services spécifiques -->
  <section class="py-20 bg-surface-container-low">
    <div class="max-w-7xl mx-auto px-6">
      <h2 class="text-3xl font-headline font-bold text-on-surface mb-12 tracking-tight">Interventions spécialisées</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-px bg-outline-variant/15">
        <div class="bg-surface-container-lowest p-12">
          <h3 class="text-xl font-headline font-bold text-on-surface mb-4">Renault Zoe — Roulement moteur</h3>
          <p class="text-on-surface-variant font-light leading-relaxed mb-4">
            Problème courant : bruits anormaux, bourdonnement, vibrations. Nous réparons le roulement moteur ou proposons un moteur échange standard.
          </p>
          <ul class="space-y-2 text-sm text-on-surface-variant">
            <li class="flex items-center gap-2">
              <span class="material-symbols-outlined text-primary text-sm">check_circle</span>
              Diagnostic vibratoire précis
            </li>
            <li class="flex items-center gap-2">
              <span class="material-symbols-outlined text-primary text-sm">check_circle</span>
              Remplacement roulement ou moteur échange
            </li>
          </ul>
        </div>
        <div class="bg-surface-container-lowest p-12">
          <h3 class="text-xl font-headline font-bold text-on-surface mb-4">Tesla — Large Drive Unit (LDU)</h3>
          <p class="text-on-surface-variant font-light leading-relaxed mb-4">
            Réparation spécialisée des LDU Tesla. Diagnostic complet, réparation des composants internes, restauration des performances nominales.
          </p>
          <ul class="space-y-2 text-sm text-on-surface-variant">
            <li class="flex items-center gap-2">
              <span class="material-symbols-outlined text-primary text-sm">check_circle</span>
              Expertise Tesla certifiée
            </li>
            <li class="flex items-center gap-2">
              <span class="material-symbols-outlined text-primary text-sm">check_circle</span>
              Test dynamométrique après réparation
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Pricing -->
  <section class="py-20 bg-surface">
    <div class="max-w-7xl mx-auto px-6">
      <h2 class="text-3xl font-headline font-bold text-on-surface mb-12 tracking-tight">Tarifs</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-px bg-outline-variant/15">
        {pricing.map((plan) => (
          <div class="bg-surface-container-lowest p-12">
            <h3 class="text-xl font-headline font-bold text-on-surface mb-2">{plan.name}</h3>
            <p class="text-sm text-on-surface-variant mb-6">{plan.description}</p>
            <div class="text-4xl font-headline font-bold text-primary mb-6">{plan.price}</div>
            <div class="flex items-center gap-3 text-sm">
              <span class="material-symbols-outlined text-primary text-sm">schedule</span>
              <span class="text-on-surface-variant">Délai : {plan.turnaround}</span>
            </div>
          </div>
        ))}
      </div>
      <p class="text-sm text-on-surface-variant mt-8 font-light">
        Tarifs TTC. Entretien préventif recommandé tous les 50 000 à 100 000 km.
      </p>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 bg-surface-container-low">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <h2 class="text-3xl font-headline font-bold text-on-surface mb-6 tracking-tight">Votre moteur a besoin d'attention ?</h2>
      <p class="text-on-surface-variant font-light mb-8">Bruit anormal, perte de puissance, vibrations — prenez rendez-vous pour un diagnostic moteur.</p>
      <a href="/reservation" class="inline-block bg-gradient-to-r from-primary to-primary-container text-on-primary px-12 py-5 rounded-md font-headline font-bold tracking-tight hover:opacity-90 transition-all">
        Réserver un diagnostic moteur
      </a>
    </div>
  </section>

</BaseLayout>
