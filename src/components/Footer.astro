---
const year = new Date().getFullYear();
---

<footer class="bg-zinc-50 w-full py-12 border-t border-zinc-200/15">
  <div class="max-w-7xl mx-auto px-6 grid grid-cols-1 md:grid-cols-2 gap-8">
    <div>
      <a href="/" class="font-headline font-bold text-zinc-900 text-2xl mb-4 block">
        EV Clinic Paris
      </a>
      <p class="font-body text-sm uppercase tracking-widest text-zinc-500 max-w-sm">
        © {year} EV Clinic Paris. Ingénierie de précision pour l'ère électrique.
      </p>
    </div>
    <div class="flex flex-wrap gap-x-12 gap-y-4 md:justify-end items-center">
      <a class="font-body text-sm uppercase tracking-widest text-zinc-500 hover:text-emerald-500 transition-colors duration-200" href="/mentions-legales">
        Mentions légales
      </a>
      <a class="font-body text-sm uppercase tracking-widest text-zinc-500 hover:text-emerald-500 transition-colors duration-200" href="/contact">
        Contact
      </a>
    </div>
  </div>
</footer>
