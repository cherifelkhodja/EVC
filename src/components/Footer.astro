---
import Logo from './Logo.astro';
const year = new Date().getFullYear();

const services = [
  { label: 'Batteries HV', href: '/batteries' },
  { label: 'Moteurs électriques', href: '/moteurs' },
  { label: 'Onduleurs & DC/DC', href: '/onduleurs' },
  { label: 'Tous les services', href: '/services' },
];

const navigation = [
  { label: 'Accueil', href: '/' },
  { label: 'À propos', href: '/a-propos' },
  { label: 'Contact', href: '/contact' },
  { label: 'Réservation', href: '/reservation' },
];

const legal = [
  { label: 'Mentions légales', href: '/mentions-legales' },
];
---

<footer class="bg-inverse-surface text-inverse-on-surface w-full">
  <!-- Main footer -->
  <div class="max-w-7xl mx-auto px-6 py-16">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-12 md:gap-8">

      <!-- Brand + contact -->
      <div class="md:col-span-4">
        <div class="mb-4">
          <Logo class="text-3xl" variant="light" showTagline />
        </div>
        <p class="text-zinc-400 text-sm leading-relaxed mb-6">
          Atelier spécialisé dans la réparation de véhicules électriques. Batteries HV, moteurs, onduleurs.
        </p>
        <div class="space-y-2 text-sm text-zinc-400">
          <div class="flex items-start gap-3">
            <span class="material-symbols-outlined text-primary-fixed-dim text-base mt-0.5 shrink-0">location_on</span>
            <span>3-7 rue Georges Besse<br/>Bâtiment Lavoisier, 92160 Antony</span>
          </div>
          <div class="flex items-center gap-3">
            <span class="material-symbols-outlined text-primary-fixed-dim text-base shrink-0">mail</span>
            <a href="mailto:contact@evclinic.fr" class="hover:text-white transition-colors">contact@evclinic.fr</a>
          </div>
          <div class="flex items-center gap-3">
            <span class="material-symbols-outlined text-primary-fixed-dim text-base shrink-0">schedule</span>
            <span>Lun — Ven, 9h — 17h</span>
          </div>
        </div>
      </div>

      <!-- Services -->
      <div class="md:col-span-3 md:col-start-6">
        <h3 class="font-headline font-bold text-white text-sm uppercase tracking-widest mb-6">Services</h3>
        <ul class="space-y-3">
          {services.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-zinc-400 hover:text-white transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Navigation -->
      <div class="md:col-span-2">
        <h3 class="font-headline font-bold text-white text-sm uppercase tracking-widest mb-6">Navigation</h3>
        <ul class="space-y-3">
          {navigation.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-zinc-400 hover:text-white transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Legal -->
      <div class="md:col-span-2">
        <h3 class="font-headline font-bold text-white text-sm uppercase tracking-widest mb-6">Légal</h3>
        <ul class="space-y-3">
          {legal.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-zinc-400 hover:text-white transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-zinc-700/50">
    <div class="max-w-7xl mx-auto px-6 py-6 flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="text-xs text-zinc-500">
        © {year} EV Clinic Paris — Membre du réseau international EV Clinic
      </p>
      <p class="text-xs text-zinc-500">
        Sur rendez-vous uniquement
      </p>
    </div>
  </div>
</footer>
