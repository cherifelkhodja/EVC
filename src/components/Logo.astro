---
interface Props {
  class?: string;
  variant?: 'dark' | 'light';
}

const { class: className = '', variant = 'dark' } = Astro.props;
const filter = variant === 'light' ? 'brightness(0) invert(1)' : 'none';
---

<a href="/" class:list={['inline-block', className]}>
  <img
    src="/images/logo.png"
    alt="EVC — Electric Vehicles Clinic"
    class="h-full w-auto object-contain"
    style={`filter: ${filter};`}
  />
</a>
