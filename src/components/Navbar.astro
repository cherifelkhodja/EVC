---
import Logo from './Logo.astro';

const currentPath = Astro.url.pathname;

const navLinks = [
  { href: '/', label: 'Accueil' },
  { href: '/services', label: 'Services' },
  { href: '/a-propos', label: 'À propos' },
  { href: '/rse', label: 'RSE' },
  { href: '/contact', label: 'Contact' },
];
---

<nav class="fixed top-0 w-full z-50 bg-white/80 backdrop-blur-xl transition-opacity">
  <div class="flex items-center max-w-7xl mx-auto px-6 h-20">
    <Logo class="h-12" />

    <div class="hidden md:flex items-center space-x-8 font-headline tracking-tight ml-auto mr-8">
      {navLinks.map((link) => {
        const isActive = currentPath === link.href || currentPath === link.href + '/';
        return (
          <a
            href={link.href}
            class={isActive
              ? 'text-emerald-600 border-b-2 border-emerald-600 pb-1'
              : 'text-zinc-600 hover:text-zinc-900 transition-colors'}
          >
            {link.label}
          </a>
        );
      })}
    </div>

    <a
      href="/reservation"
      class="hidden sm:inline-block bg-gradient-to-r from-primary to-primary-container text-on-primary px-8 py-3 rounded-md font-headline font-bold text-sm tracking-wide hover:opacity-80 transition-opacity active:scale-95 duration-150"
    >
      Réserver
    </a>

    <!-- Mobile menu button -->
    <button
      id="mobile-menu-btn"
      class="md:hidden flex flex-col gap-1.5 p-2 ml-auto"
      aria-label="Menu"
      aria-expanded="false"
    >
      <span class="w-6 h-0.5 bg-zinc-900 transition-transform" id="bar1"></span>
      <span class="w-6 h-0.5 bg-zinc-900 transition-opacity" id="bar2"></span>
      <span class="w-6 h-0.5 bg-zinc-900 transition-transform" id="bar3"></span>
    </button>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden bg-white/95 backdrop-blur-xl border-t border-zinc-200/50">
    <div class="flex flex-col px-6 py-4 space-y-4 font-headline">
      {navLinks.map((link) => {
        const isActive = currentPath === link.href || currentPath === link.href + '/';
        return (
          <a
            href={link.href}
            class={isActive
              ? 'text-emerald-600 font-bold'
              : 'text-zinc-600 hover:text-zinc-900 transition-colors'}
          >
            {link.label}
          </a>
        );
      })}
      <a
        href="/reservation"
        class="bg-gradient-to-r from-primary to-primary-container text-on-primary px-6 py-3 rounded-md font-bold text-sm text-center"
      >
        Réserver
      </a>
    </div>
  </div>
</nav>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
    const isOpen = !menu?.classList.contains('hidden');
    btn?.setAttribute('aria-expanded', String(isOpen));
  });
</script>
